<?xml version="1.0"?>
<robot name="six_wheel_rover" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- Properties -->
  <xacro:property name="wheel_radius" value="0.1"/>
  <xacro:property name="wheel_width" value="0.05"/>
  <xacro:property name="wheel_base" value="0.5"/>
  <xacro:property name="track_width" value="0.4"/>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="10.0"/>
      <inertia ixx="1" iyy="1" izz="1" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.6 0.4 0.2"/>
      </geometry>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.6 0.4 0.2"/>
      </geometry>
    </collision>
  </link>

  <!-- Macro for wheel -->
  <xacro:macro name="wheel" params="name parent x y steering">
    <!-- steering joint link -->
    <link name="${name}_link">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>

    <joint name="${name}_steer_joint" type="${steering}">
      <parent link="${parent}"/>
      <child link="${name}_link"/>
      <origin xyz="${x} ${y} 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit effort="10" velocity="2.0" lower="-1.0" upper="1.0"/>
    </joint>

    <joint name="${name}_wheel_joint" type="continuous">
      <parent link="${name}_link"/>
      <child link="${name}_wheel"/>
      <origin xyz="0 0 -${wheel_radius}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>

    <link name="${name}_wheel">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>

  <!-- Front left (steered) -->
  <xacro:wheel name="fl" parent="base_link"
               x="${wheel_base/2}" y="${track_width/2}" steering="revolute"/>
  <xacro:wheel name="ml" parent="base_link"
               x="0.0" y="${track_width/2}" steering="fixed"/>
  <xacro:wheel name="rl" parent="base_link"
               x="-${wheel_base/2}" y="${track_width/2}" steering="revolute"/>

  <!-- Right side (mirror) -->
  <xacro:wheel name="fr" parent="base_link"
               x="${wheel_base/2}" y="-${track_width/2}" steering="revolute"/>
  <xacro:wheel name="mr" parent="base_link"
               x="0.0" y="-${track_width/2}" steering="fixed"/>
  <xacro:wheel name="rr" parent="base_link"
               x="-${wheel_base/2}" y="-${track_width/2}" steering="revolute"/>

</robot>
